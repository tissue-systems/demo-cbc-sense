// config.h — compile-time tunables. COPY this file to config.h and edit if needed.
//
//   cp include/config.h.example include/config.h   (or: make config)
//
// There are NO secrets here. Wi-Fi credentials are entered by the user at runtime
// through the captive portal; the per-device reporting credentials are obtained at
// runtime when the device links to your account, and stored in the ESP8266's own
// flash (LittleFS). These are just build-time constants.

#pragma once

// ── Sensor ───────────────────────────────────────────────────────────────
// DATA line. D4 == GPIO2 — the pin silk-printed "2", next to GND. NOTE: GPIO2
// also drives the onboard LED, so the LED can't blink while the sensor lives
// here — serial is the status channel (see LED_AVAILABLE in main.cpp).
#define DHT_PIN             D4        // GPIO2 (silk "2")

// How often to read + publish. Once a minute is the supported cadence for
// regular tissue accounts (faster readings are rate-controlled server-side).
// The DHT22's own minimum sample period is 2s.
#define REPORT_INTERVAL_MS  60000UL

// ── Captive portal ───────────────────────────────────────────────────────
// SoftAP name shown to the user; a 4-hex chip suffix is appended at runtime,
// e.g. "tissue-sense-3F9A".
#define AP_NAME_PREFIX      "tissue-sense"
#define PORTAL_TIMEOUT_S    180       // give up the portal after N seconds idle

// The setup page the QR code points to (shown in the portal for context).
#define WORKSHOP_URL        "https://cbc.tissue.dev"

// ── Account link ─────────────────────────────────────────────────────────
// Public setup endpoint the device calls after Wi-Fi to link itself to your
// account. It polls here until you've completed signup on the setup page.
//
// NOTE: this MAC-based claim flow is for the CBC demo devices only — it only
// works for boards whose MAC was pre-registered at the prep bench. For a
// regular device of your own, skip the claim flow entirely: register the
// device with the ribo CLI (`ribo sensor add <cell>`) — or in the dashboard
// under Synapse — and put the returned credentials on the device. See
// https://docs.tissue.systems/docs/synapse/byo-device/
#define CLAIM_URL           "https://auth.tissue.systems/api/sense/claim"
#define CLAIM_POLL_MS       5000UL    // delay between link attempts while waiting

// ── Ingest (default; the account-link response can override the host) ────────
#define INGEST_HOST         "ingest.tissue.dev"
#define INGEST_PORT         8883
#define METRIC_PREFIX       "env"     // metrics land at <prefix>/temperature, <prefix>/humidity
